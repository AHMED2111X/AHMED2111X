#!/system/bin/sh
MODDIR="/data/adb/modules/falcon_integrity_fix"
TS_PATH="/data/adb/tricky_store"

clear
echo "  ######################################"
echo "  #      🦅 FALCON TERMINAL v2.18      #"
echo "  #          Developer: ABUFARID       #"
echo "  ######################################"
echo " "
echo "1) 🚀 وضع الوحش (165 FPS + تزييف الحالة)"
echo "2) 🧹 تنظيف الكاش الذكي (GMS & Store)"
echo "3) 🗑️ حذف ملفات الـ BAK وتنظيف المسار"
echo "4) ❌ خروج"
echo " "
read -p "اختر رقم العملية: " choice

case $choice in
    1)
        settings put signature min_refresh_rate 165.0[cite: 12, 13]
        settings put signature peak_refresh_rate 165.0[cite: 12, 13]
        echo "✅ تم تفعيل الأداء الأقصى وتزييف الحالة!"
        ;;
    2)
        echo "تفريغ كاش Google Services..."
        # تنظيف الكاش بدون المساس بالحسابات
        rm -rf /data/data/com.google.android.gms/cache/*[cite: 11, 13]
        rm -rf /data/data/com.android.vending/cache/*[cite: 11, 13]
        echo "✅ تم التنظيف الذكي بنجاح!"
        ;;
    3)
        echo "جاري تنظيف كافة ملفات الباك..."
        # حذف شامل لأي ملف ينتهي بـ .bak مهما كان اسمه[cite: 12, 13]
        rm -f $TS_PATH/*.bak[cite: 12, 13]
        rm -f $TS_PATH/*.tmp[cite: 12, 13]
        echo "✅ تم تنظيف جميع الملفات الاحتياطية بنجاح."
        ;;
    *)
        exit
        ;;
esac